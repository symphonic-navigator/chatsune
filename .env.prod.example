# Public hostname Chatsune will be served from. Used by both Traefik
# labels (routing rule) and the backend (CORS allow-list). No scheme,
# no trailing slash.
CHATSUNE_HOST=chatsune.example.com

# First-time setup PIN for POST /api/setup (creates the master admin).
# Change this to a real value, then discard it after first login.
MASTER_ADMIN_PIN=change-me-1234

# JWT signing secret. Generate with:
#   openssl rand -hex 32
JWT_SECRET=change-me-generate-a-real-secret

# Fernet key for encrypting user API keys at rest. Must be url-safe
# base64 decoding to exactly 32 bytes. Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# Optional: separate key for signing avatar URLs. Falls back to JWT_SECRET
# with a startup warning if unset. Generate the same way as JWT_SECRET.
# AVATAR_SIGNING_KEY=

# Optional: cookie domain for the refresh-token cookie. Leave unset for a
# host-only cookie (works for single-host same-origin deploys). Set to a
# parent domain like `.example.com` only if you need the cookie shared
# across subdomains (e.g. api.example.com + app.example.com).
# COOKIE_DOMAIN=
