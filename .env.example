# Master admin setup — required for first-time setup via POST /api/setup
MASTER_ADMIN_PIN=change-me-1234

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-a-real-secret

# MongoDB — must include replicaSet=rs0 for transactions and vector search
MONGODB_URI=mongodb://mongodb:27017/chatsune?replicaSet=rs0

# Redis — used for refresh tokens and event streams
REDIS_URI=redis://redis:6379/0

# Fernet key for encrypting API keys at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# File uploads — storage root path and per-user quota in bytes (default 1 GB)
UPLOAD_ROOT=/data/uploads
UPLOAD_QUOTA_BYTES=1073741824

# Avatar storage — root path for persona profile pictures
AVATAR_ROOT=/data/avatars

# Optional cookie domain for the refresh-token cookie. Leave unset for default
# (host-only cookie). Set to a parent domain (e.g. ".example.com") only if you
# need the cookie shared across subdomains.
# COOKIE_DOMAIN=

# Embedding model weights — downloaded on first start if missing
EMBEDDING_MODEL_DIR=./data/models
EMBEDDING_BATCH_SIZE=8

# LLM Test Harness — Ollama Cloud API key for direct LLM testing.
# Place your key in .llm-test-key (plain text, single line) in the project root.
# This file is gitignored. Used by: uv run python -m backend.llm_harness

# Override the base URL the backend uses to talk to a local Ollama daemon.
# Defaults to http://localhost:11434 if unset.
OLLAMA_LOCAL_BASE_URL=http://localhost:11434

# Safeguards
# Hard safeguards protecting testers from runaway background-job cost.
# All values can be tuned without a code change — restart the backend after
# editing. Setting a numeric limit to 0 disables that particular safeguard.

# Global kill-switch for the Ollama Cloud provider. When "true" the LLM
# adapter rejects every new Ollama Cloud request immediately. Flip to "true"
# in an emergency and reload the backend — no redeploy required.
OLLAMA_CLOUD_EMERGENCY_STOP=false

# Rolling window (seconds) used by the per-user/provider rate limiter.
JOB_RATE_LIMIT_WINDOW_SECONDS=60

# Maximum LLM calls a single user may issue against one provider within
# the rate-limit window. 0 disables the rate limiter.
JOB_RATE_LIMIT_MAX_CALLS=50

# Maximum number of queued background jobs per user before new submits are
# rejected with a "queue full" error. 0 disables the queue cap.
JOB_QUEUE_CAP_PER_USER=10

# Daily token budget per user across all background-job LLM calls.
# Counter resets at 00:00 UTC. 0 disables the daily budget.
JOB_DAILY_TOKEN_BUDGET=5000000

# Circuit breaker — failures tolerated within the window before the provider
# circuit opens. 0 disables the circuit breaker.
JOB_CIRCUIT_FAILURE_THRESHOLD=5

# Circuit breaker rolling window (seconds) over which failures are counted.
JOB_CIRCUIT_WINDOW_SECONDS=300

# How long the circuit stays open (seconds) after tripping, during which all
# new requests to the affected provider are rejected fast.
JOB_CIRCUIT_OPEN_SECONDS=900
